# Local path to the SSH known_hosts file used by deploy.sh.
KNOWN_HOSTS_FILE=/tmp/mediaserver-known_hosts

# Remote SSH username for deployment.
REMOTE_USER=deploy
# Remote SSH host or IP for deployment.
REMOTE_HOST=192.168.1.50
# Remote SSH password used by sshpass.
REMOTE_PASSWORD=change-me
# Remote sudo password. Set it equal to REMOTE_PASSWORD if they are the same.
REMOTE_SUDO_PASSWORD=change-me
# Base directory on the remote host where all stacks are deployed.
REMOTE_BASE_DIR=/opt/media-server

# UID that should own media files and writable service data on the remote host.
MEDIA_UID=1000
# GID that should own media files and writable service data on the remote host.
MEDIA_GID=1000

# Default timezone used by services that need it.
TZ=UTC
# Default PUID used by linuxserver-style containers.
PUID=1000
# Default PGID used by linuxserver-style containers.
PGID=1000
# Default umask applied by linuxserver-style containers.
UMASK_SET=022

# Public scheme used to build externally visible URLs.
PUBLIC_SCHEME=http
# Public hostname used to access the server from browsers.
PUBLIC_HOST=media.example.internal
# Base public URL used by services behind nginx.
PUBLIC_BASE_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}
# Hosts allowed by Homepage.
# Include the public hostname, localhost and any direct LAN IP used to open /dashboard.
DASHBOARD_ALLOWED_HOSTS=${PUBLIC_HOST},localhost,127.0.0.1,${REMOTE_HOST}

# Public port exposed by the dashboard service.
DASHBOARD_PORT=3000
# Public HTTP port exposed by Portainer.
PORTAINER_HTTP_PORT=9000
# Public HTTPS port exposed by Portainer.
PORTAINER_HTTPS_PORT=9443
# Public port exposed by Yacht.
YACHT_PORT=8000
# Public HTTP port exposed by nginx for the mediaserver gateway.
NGINX_HTTP_PORT=80

# Public dashboard URL shown in the mediaserver index page.
DASHBOARD_URL=${PUBLIC_BASE_URL}/dashboard/
# Public Portainer URL shown in the mediaserver index page.
PORTAINER_URL=${PUBLIC_BASE_URL}/portainer/
# Public Yacht URL shown in the mediaserver index page.
YACHT_URL=${PUBLIC_BASE_URL}/yacht/

# Pi-hole HTTP port inside the Docker network. It is not published to the LAN.
PIHOLE_HTTP_PORT=80
# Pi-hole admin password.
PIHOLE_WEBPASSWORD=password
# Pi-hole DNSMASQ listening mode.
PIHOLE_DNSMASQ_LISTENING=local
# Pi-hole URL shown in the mediaserver index page. It is routed through nginx.
PIHOLE_URL=${PUBLIC_BASE_URL}/pihole/admin/
# Pi-hole upstream URL used by nginx.
PIHOLE_UPSTREAM_URL=http://pihole:${PIHOLE_HTTP_PORT}

# Transmission container hostname on the Docker network.
TRANSMISSION_HOST=perigo
# Transmission RPC port used internally and by health checks.
TRANSMISSION_RPC_PORT=9091
# Transmission home directory inside the container.
TRANSMISSION_HOME=/config/transmission-home
# Transmission RPC username. Leave blank if authentication is disabled.
TRANSMISSION_RPC_USERNAME=
# Transmission RPC password. Leave blank if authentication is disabled.
TRANSMISSION_RPC_PASSWORD=
# Transmission completed downloads directory inside the container.
TRANSMISSION_DOWNLOAD_DIR=/downloads/completed
# Transmission incomplete downloads directory inside the container.
TRANSMISSION_INCOMPLETE_DIR=/downloads/incomplete
# Transmission watched folder inside the container.
TRANSMISSION_WATCH_DIR=/watch
# Transmission bind address.
TRANSMISSION_BIND_ADDRESS_IPV4=0.0.0.0
# Transmission upstream URL used by nginx.
TRANSMISSION_UPSTREAM_URL=http://${TRANSMISSION_HOST}:${TRANSMISSION_RPC_PORT}
# Homepage upstream URL used by nginx.
DASHBOARD_UPSTREAM_URL=http://homepage:${DASHBOARD_PORT}
# Transmission image log-to-stdout toggle.
LOG_TO_STDOUT=false

# Lidarr container hostname on the Docker network.
LIDARR_HOST=lidarr
# Lidarr internal port.
LIDARR_PORT=8686
# Lidarr internal base URL used by integrations.
LIDARR_INTERNAL_URL=http://${LIDARR_HOST}:${LIDARR_PORT}
# Lidarr upstream URL used by nginx.
LIDARR_UPSTREAM_URL=${LIDARR_INTERNAL_URL}

# Radarr container hostname on the Docker network.
RADARR_HOST=radarr
# Radarr internal port.
RADARR_PORT=7878
# Radarr internal base URL used by integrations.
RADARR_INTERNAL_URL=http://${RADARR_HOST}:${RADARR_PORT}
# Radarr external URL used by Jellyseerr.
RADARR_EXTERNAL_URL=${PUBLIC_BASE_URL}/radarr
# Radarr upstream URL used by nginx.
RADARR_UPSTREAM_URL=${RADARR_INTERNAL_URL}

# Sonarr container hostname on the Docker network.
SONARR_HOST=sonarr
# Sonarr internal port.
SONARR_PORT=8989
# Sonarr internal base URL used by integrations.
SONARR_INTERNAL_URL=http://${SONARR_HOST}:${SONARR_PORT}
# Sonarr external URL used by Jellyseerr.
SONARR_EXTERNAL_URL=${PUBLIC_BASE_URL}/sonarr
# Sonarr upstream URL used by nginx.
SONARR_UPSTREAM_URL=${SONARR_INTERNAL_URL}

# Prowlarr container hostname on the Docker network.
PROWLARR_HOST=prowlarr
# Prowlarr internal port.
PROWLARR_PORT=9696
# Prowlarr internal base URL used by integrations.
PROWLARR_INTERNAL_URL=http://${PROWLARR_HOST}:${PROWLARR_PORT}
# Legacy Prowlarr URLs that should be rewritten in app databases.
LEGACY_PROWLARR_URLS=http://192.168.1.10:9696,${PUBLIC_BASE_URL}/prowlarr
# Prowlarr upstream URL used by nginx.
PROWLARR_UPSTREAM_URL=${PROWLARR_INTERNAL_URL}

# FlareSolverr internal port.
FLARESOLVERR_PORT=8191
# FlareSolverr upstream URL used by nginx.
FLARESOLVERR_UPSTREAM_URL=http://flaresolverr:${FLARESOLVERR_PORT}

# Jellyseerr internal port.
JELLYSEERR_PORT=5055
# Jellyseerr upstream URL used by nginx.
JELLYSEERR_UPSTREAM_URL=http://jellyseerr:${JELLYSEERR_PORT}

# Jellyfin container hostname on the Docker network.
JELLYFIN_HOST=jellyfin
# Jellyfin internal port.
JELLYFIN_PORT=8096
# Jellyfin external URL exposed through nginx.
JELLYFIN_EXTERNAL_URL=${PUBLIC_BASE_URL}/jellyfin
# Jellyfin forgot-password URL exposed through nginx.
JELLYFIN_FORGOT_PASSWORD_URL=${PUBLIC_BASE_URL}/jellyfin/web/#/forgotpassword.html
# Jellyfin upstream URL used by nginx.
JELLYFIN_UPSTREAM_URL=http://${JELLYFIN_HOST}:${JELLYFIN_PORT}
# Portainer upstream URL used by nginx.
PORTAINER_UPSTREAM_URL=http://portainer:${PORTAINER_HTTP_PORT}
# Yacht upstream URL used by nginx.
YACHT_UPSTREAM_URL=http://yacht:${YACHT_PORT}

# Linuxserver permission helper toggle.
GLOBAL_APPLY_PERMISSIONS=false
# Extra health check hostname used by the transmission image.
HEALTH_CHECK_HOST=google.com
# Transmission self-heal toggle.
SELFHEAL=false
# Image revision string kept from the current stack.
REVISION=07f5a2b9aea5028c9bb75438c1552708e91dde71
# Optional local network CIDRs for linuxserver images. Leave blank if unused.
LOCAL_NETWORK=
# Verbose logging toggle for linuxserver images.
DEBUG=true
